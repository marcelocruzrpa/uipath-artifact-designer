{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [],
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "webview/**/*.ts",
    "webview/**/*.d.ts",
    "src/model/artifactKind.ts",
    "src/model/types.ts",
    "src/model/layout.ts",
    "src/model/flow/flowTypes.ts",
    "src/model/case/caseTypes.ts",
    "src/util/messages.ts",
    "src/util/jsonShape.ts",
    "src/util/objects.ts"
  ]
}
